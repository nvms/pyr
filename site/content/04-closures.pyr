---
title: closures
order: 4
---
// closures are anonymous functions created with `fn`.
// they capture variables from their enclosing scope.
fn main() {
  multiplier = 3
  triple = fn(x) x * multiplier

  println(triple(5))
  println(triple(10))

// closures can be passed to other functions.
  apply(7, fn(x) x + 1)
}

// a function that takes a closure as an argument.
fn apply(val: int, f) {
  println(f(val))
}
