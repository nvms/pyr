---
title: modules
order: 13
---
// `imp` imports from stdlib or local files.
// selective import pulls specific names into scope.
imp std/io { println, print }

// namespace import keeps the module prefix.
imp std/fs

// aliased import renames the module.
imp std/os as system

fn main() {
  println("hello from std/io")

// namespace access uses dot syntax.
  exists = fs.exists("README.md")
  println(exists)

// aliased module access.
  name = system.env("USER") or "unknown"
  println(name)
}
