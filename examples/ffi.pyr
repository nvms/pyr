extern "c" {
  fn getpid() -> cint
  fn strlen(s: cstr) -> cint
  fn getenv(name: cstr) -> cstr
  fn abs(n: cint) -> cint
}

fn main() {
  pid = getpid()
  assert(pid > 0)

  assert_eq(strlen("hello"), 5)
  assert_eq(strlen(""), 0)
  assert_eq(strlen("hello world"), 11)

  home = getenv("HOME")
  assert(strlen(home) > 0)

  missing = getenv("NONEXISTENT_VAR_XYZ_123")
  assert_eq(missing, nil)

  assert_eq(abs(-42), 42)
  assert_eq(abs(0), 0)
  assert_eq(abs(7), 7)

  println("ok")
}
