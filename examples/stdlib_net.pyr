imp std/net as net

fn main() {
  server = net.listen("127.0.0.1", 19877)
  assert(server != nil)

  client = net.connect("127.0.0.1", 19877)
  assert(client != nil)

  conn = net.accept(server)
  assert(conn != nil)

  net.write(client, "ping")
  data = net.read(conn)
  assert_eq(data, "ping")
  println(data)

  net.write(conn, "pong")
  reply = net.read(client)
  assert_eq(reply, "pong")
  println(reply)

  net.close(conn)
  net.close(client)
  net.close(server)
  println("done")
}
