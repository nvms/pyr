struct Point {
  x: int
  y: int
}

fn translate(p: Point, dx: int, dy: int) {
  p.x += dx
  p.y += dy
}

fn main() {
  mut p = Point { x: 1, y: 2 }
  println(p.x)
  println(p.y)

  p.x = 10
  p.y = 20
  println(p.x)
  println(p.y)

  translate(p, 5, -3)
  println(p.x)
  println(p.y)

  mut grid = [0, 0, 0, 0, 0]
  for i in range(5) {
    grid[i] = i * i
  }
  for i in range(5) {
    println(grid[i])
  }

  grid[2] += 100
  println(grid[2])
}
