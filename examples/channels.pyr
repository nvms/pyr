imp std/io { println }

fn producer(ch, start: int, count: int) {
  mut i = start
  while i < start + count {
    ch.send(i)
    i = i + 1
  }
}

fn main() {
  ch = channel(2)

  spawn { producer(ch, 0, 5) }

  mut i = 0
  while i < 5 {
    msg = ch.recv()
    println(msg)
    i = i + 1
  }

  ch2 = channel(10)
  spawn { ch2.send(100) }
  spawn { ch2.send(200) }
  spawn { ch2.send(300) }
  println(ch2.recv())
  println(ch2.recv())
  println(ch2.recv())
}
